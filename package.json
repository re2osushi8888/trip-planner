{
  "name": "trip-planner",
  "version": "1.0.0",
  "private": true,
  "description": "Trip planner application with TypeScript and Hono",
  "keywords": [],
  "license": "ISC",
  "author": "",
  "type": "module",
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "build": "vp run -r build",
    "check": "vp run -r check",
    "fix": "vp run -r fix",
    "lint": "vp run -r lint",
    "format": "vp run -r format",
    "type-check": "vp run -r type-check",
    "ls-lint": "ls-lint",
    "commit": "git-cz"
  },
  "devDependencies": {
    "@commitlint/cli": "20.4.4",
    "@commitlint/config-conventional": "20.4.4",
    "@commitlint/cz-commitlint": "20.4.4",
    "@ls-lint/ls-lint": "2.3.1",
    "codex": "^0.2.3",
    "commitizen": "4.3.1",
    "inquirer": "9.3.8",
    "lefthook": "2.1.4",
    "oxc": "1.0.1",
    "vite-plus": "catalog:"
  },
  "config": {
    "commitizen": {
      "path": "@commitlint/cz-commitlint"
    }
  },
  "packageManager": "pnpm@10.32.1"
}
