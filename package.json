{
  "name": "trip-planner",
  "version": "1.0.0",
  "description": "Trip planner application with TypeScript and Hono",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "oxlint .",
    "format": "oxc format --write .",
    "format:check": "oxc format .",
    "type-check": "turbo type-check",
    "ls-lint": "ls-lint",
    "commit": "git-cz"
  },
  "config": {
    "commitizen": {
      "path": "@commitlint/cz-commitlint"
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.32.1",
  "devDependencies": {
    "@commitlint/cli": "20.4.4",
    "@commitlint/config-conventional": "20.4.4",
    "@commitlint/cz-commitlint": "20.4.4",
    "@ls-lint/ls-lint": "2.3.1",
    "commitizen": "4.3.1",
    "inquirer": "9.3.8",
    "lefthook": "2.1.4",
    "oxc": "1.0.1",
    "oxlint": "1.54.0",
    "turbo": "2.8.16"
  }
}
